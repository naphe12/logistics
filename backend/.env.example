DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/postgres
JWT_SECRET_KEY=change-me
APP_VERSION=dev

# CORS
CORS_ALLOW_ALL=true
CORS_ALLOW_ORIGIN_REGEX=^https?://.+$

# Media storage for delivery proof photos
# Local default: backend/media
# Railway recommended: /data/media (mounted volume)
MEDIA_ROOT=/data/media
